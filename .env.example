# Supabase 프로젝트 설정 (Supabase 대시보드 > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 세션 서명용 비밀키 (아무 긴 랜덤 문자열)
SESSION_SECRET=change-me-to-a-long-random-string

# 사진 보관 개월 수 (기본 6) — 이 기간이 지난 사진 파일은 자동 삭제, 출근 기록·통계는 보존
PHOTO_RETENTION_MONTHS=6

# PIN 재설정 인증 메일 발송 (resend.com API 키). 없으면 개발 환경에선 콘솔에 코드 출력
RESEND_API_KEY=
# 발신자 주소 (Resend에 등록된 도메인). 생략 시 onboarding@resend.dev
MAIL_FROM=쿵야출근단 <noreply@yourdomain.com>

# 로컬 개발/테스트용: 1이면 Supabase 없이 메모리 DB 사용 (서버 재시작 시 초기화)
MOCK_DB=0
