# Supabase 프로젝트 설정 (Supabase 대시보드 > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# 세션 서명용 비밀키 (아무 긴 랜덤 문자열)
SESSION_SECRET=change-me-to-a-long-random-string

# 사진 보관 개월 수 (기본 6) — 이 기간이 지난 사진 파일은 자동 삭제, 출근 기록·통계는 보존
PHOTO_RETENTION_MONTHS=6

# 운영자 이메일 — PIN 재설정 화면의 "운영자에게 메일 보내기" 링크에 사용 (화면에 노출됨)
NEXT_PUBLIC_OPERATOR_EMAIL=you@example.com

# 로컬 개발/테스트용: 1이면 Supabase 없이 메모리 DB 사용 (서버 재시작 시 초기화)
MOCK_DB=0
